PORT=3001
NODE_ENV=development

# Supabase (server-side service role)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Auth (JWT)
JWT_SECRET=change-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-me-too
JWT_REFRESH_EXPIRES_IN=30d
JWT_ISSUER=
JWT_AUDIENCE=

# CORS (required in production)
# Comma-separated list of allowed browser origins, e.g.:
# CORS_ORIGINS=https://yourapp.com,https://www.yourapp.com,http://localhost:5173
CORS_ORIGINS=

# Reverse proxy (Railway/Heroku)
TRUST_PROXY=1

# Refresh cookie (httpOnly)
REFRESH_COOKIE_NAME=tv_refresh
REFRESH_COOKIE_MAX_AGE_DAYS=30
# If you host frontend + API on different sites (e.g. Vercel + Railway), you likely need:
# COOKIE_SAMESITE=none and COOKIE_SECURE=true
COOKIE_SAMESITE=
COOKIE_SECURE=
COOKIE_DOMAIN=

# Rate limiting
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_API_WINDOW_MS=900000
RATE_LIMIT_API_MAX=600

# Body size limit (Express json)
JSON_LIMIT=1mb

# Email verification
# - `EMAIL_VERIFICATION_URL_BASE` should point to your frontend route, e.g.:
#   http://localhost:5173/#/verify-email
# - `EMAIL_VERIFICATION_REDIRECT_URL_BASE` should be the non-hash base URL Supabase will redirect to, e.g.:
#   http://localhost:5173/
# - `EMAIL_VERIFICATION_SECRET` defaults to `JWT_SECRET` if unset.
EMAIL_VERIFICATION_URL_BASE=
EMAIL_VERIFICATION_REDIRECT_URL_BASE=
EMAIL_VERIFICATION_SECRET=
EMAIL_VERIFICATION_EXPIRES_IN=24h

# Admin allowlist (emails)
# Comma-separated list of emails that can access /api/admin
ADMIN_EMAILS=admin@example.com
