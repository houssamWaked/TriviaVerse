## API base URL
# Dev (local API):
# VITE_API_BASE_URL=http://localhost:3001
#
# Prod (same origin; recommended when hosting API + client together, e.g. Vercel):
# VITE_API_BASE_URL=
#
# If your backend is hosted elsewhere:
# VITE_API_BASE_URL=https://trivia-verse-eight.vercel.app
VITE_API_BASE_URL=http://localhost:3001

# Comma-separated list of admin emails (must match API ADMIN_EMAILS)
VITE_ADMIN_EMAILS=admin@example.com

# Google sign-in (optional)
VITE_GOOGLE_CLIENT_ID=
