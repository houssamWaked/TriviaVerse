## API base URL
# Dev (local API):
# VITE_API_BASE_URL=http://localhost:3001
#
# Prod (same origin; recommended when hosting API + client together, e.g. Vercel):
# VITE_API_BASE_URL=
#
# If your backend is hosted elsewhere and you MUST call it directly:
# - sessions may be less reliable on mobile because refresh cookies can be treated as third-party.
# Prefer a reverse proxy / Vercel rewrite so `/api/*` stays same-origin.
VITE_API_BASE_URL=http://localhost:3001

# Comma-separated list of admin emails (must match API ADMIN_EMAILS)
VITE_ADMIN_EMAILS=admin@example.com

# Google sign-in (optional)
VITE_GOOGLE_CLIENT_ID=
